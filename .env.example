# Anthropic API 키 (인스타·스마트스토어 web_search용)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# 네이버 검색 API (카페·블로그·뉴스)
# https://developers.naver.com/apps/#/register
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# YouTube Data API (유튜브 채널)
# YOUTUBE_API_KEY=

# Meta Ad Library API (Meta 광고 채널)
# https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=
META_APP_ID=

# 선택: 사용할 Claude 모델 (기본: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5
